# ------------------------------
# Shared
# ------------------------------
PROJECT_NAME=Adarsh Optical Group CRM
ENVIRONMENT=development

# ------------------------------
# Backend
# ------------------------------
API_V1_PREFIX=/api/v1
# Production must use a unique high-entropy SECRET_KEY, not this example value.
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALLOW_LONG_REFRESH_TOKENS_IN_PRODUCTION=false
ALLOW_ADMIN_REGISTRATION=false
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_LOCKOUT_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
# Production must use a unique admin master password, not this example value.
ADMIN_MASTER_PASSWORD=eye77000
AUTH_ENFORCE_GLOBAL_EMAIL_UNIQUENESS=true

# Optional direct DB override for legacy single-database mode.
# Multi-shop production should use SHOP_DATABASES below.
DATABASE_URL=

# Required for multi-shop isolation:
# map each shop_code to its own database URL.
SHOP_DATABASES={"adarsh-optical-centre":"postgresql+psycopg2://eye_admin:eye_password@localhost:5432/adarsh_optical_centre","adarsh-optometric-clinic":"postgresql+psycopg2://eye_admin:eye_password@localhost:5432/adarsh_optometric_clinic","adarsh-opticals-muxar":"postgresql+psycopg2://eye_admin:eye_password@localhost:5432/adarsh_opticals_muxar","adarsh-eye-boutique":"postgresql+psycopg2://eye_admin:eye_password@localhost:5432/adarsh_eye_boutique"}

# Backend-only shop identifier/mobile lookup for POST /api/v1/public/shops/resolve.
# Keep real mobile numbers in your local/deployment .env, not in frontend code.
# Example: SHOP_IDENTIFIER_MAPPINGS={"9876543210":"adarsh-eye-boutique"}
SHOP_IDENTIFIER_MAPPINGS={}

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eye_boutique
POSTGRES_USER=eye_admin
POSTGRES_PASSWORD=eye_password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
BACKEND_PUBLIC_URL=http://localhost:8000
MEDIA_ROOT=storage
MEDIA_URL_PREFIX=/media
CHAT_STORAGE_ROOT=private_storage/chat
CHAT_MAX_FILE_SIZE_MB=12
CHAT_REDIS_CHANNEL=eye_boutique:shared_chat

WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_REQUEST_TIMEOUT_SECONDS=25
WHATSAPP_RETRY_ATTEMPTS=3

# ------------------------------
# CRM frontend
# ------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Adarsh Optical Group CRM

# ------------------------------
# Public website
# ------------------------------
VITE_CRM_URL=http://127.0.0.1:5173/crm
