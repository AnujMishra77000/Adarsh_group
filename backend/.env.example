PROJECT_NAME=Adarsh Optical Group CRM
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALLOW_LONG_REFRESH_TOKENS_IN_PRODUCTION=false
ALLOW_ADMIN_REGISTRATION=false
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_LOCKOUT_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
ADMIN_MASTER_PASSWORD=change-this-admin-master-password
AUTH_ENFORCE_GLOBAL_EMAIL_UNIQUENESS=true

# Optional single database (legacy mode). Tenant routing ignores this when SHOP_DATABASES is set.
DATABASE_URL=

# Required for multi-shop isolation:
# map each shop_code to its own database URL.
SHOP_DATABASES={"adarsh-optical-centre":"sqlite:///./adarsh_optical_centre.db","adarsh-optometric-clinic":"sqlite:///./adarsh_optometric_clinic.db","adarsh-opticals-muxar":"sqlite:///./adarsh_opticals_muxar.db","adarsh-eye-boutique":"sqlite:///./adarsh_eye_boutique.db"}

# Backend-only shop identifier/mobile lookup for POST /api/v1/public/shops/resolve.
# Keep real mobile numbers in your local/deployment .env, not in frontend code.
# Example: SHOP_IDENTIFIER_MAPPINGS={"9876543210":"adarsh-eye-boutique"}
SHOP_IDENTIFIER_MAPPINGS={}

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

# Shared chat module
CHAT_STORAGE_ROOT=private_storage/chat
CHAT_MAX_FILE_SIZE_MB=12
CHAT_REDIS_CHANNEL=eye_boutique:shared_chat

# WhatsApp (optional)
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# Gmail / SMTP welcome email (optional)
CUSTOMER_WELCOME_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Adarsh Optical Group
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
